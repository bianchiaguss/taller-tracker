# Base de datos
DATABASE_URL=postgresql://taller_user:taller_pass@db:5432/taller_db

# Seguridad / JWT
SECRET_KEY=cambiar-esto-por-una-clave-larga-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS - dominio del frontend
FRONTEND_URL=http://localhost:5173

# Almacenamiento de imagenes (MVP: local). Para produccion, completar con Cloudinary
STORAGE_BACKEND=local
UPLOADS_DIR=uploads
CLOUDINARY_URL=

# Email (Resend). Dejar vacio para que el sistema solo loguee el email en vez de enviarlo
RESEND_API_KEY=
EMAIL_FROM=no-responder@tutaller.com
