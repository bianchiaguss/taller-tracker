# Base de datos
DATABASE_URL=postgresql://taller_user:taller_pass@db:5432/taller_db

# Seguridad / JWT
SECRET_KEY=cambiar-esto-por-una-clave-larga-y-aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS - dominio del frontend
FRONTEND_URL=http://localhost:5173

# Almacenamiento de imagenes (MVP: local). Para produccion, completar con Cloudinary
STORAGE_BACKEND=local
UPLOADS_DIR=uploads
CLOUDINARY_URL=

# Email (Brevo API HTTP). Sin BREVO_API_KEY el sistema solo loguea (no envia).
# Render bloquea SMTP saliente en el plan free, por eso se usa API HTTP.
BREVO_API_KEY=
EMAIL_FROM_NAME=Bianchi Detailing
EMAIL_FROM_EMAIL=notificaciones.bianchi@gmail.com
